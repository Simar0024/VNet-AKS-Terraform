*.pem
*.key
*.pfx
*.crt
*.cer
*id_rsa
*id_rsa.pub
id_rsa_bastion
id_rsa_bastion.pub
certificates/

# Backup files
*.backup
*.bak
*.orig

# Test files
test-results.xml
coverage/
*.test

# Documentation build output
docs/_build/
site/

# Logs
*.log
logs/

# Python
__pycache__/
*.py[cod]
*$py.class
venv/
env/

# Node
node_modules/
npm-debug.log

# Maven
target/

# Shell scripts (personal)
*.sh
!deploy.sh
!scripts/*.sh

# IDE settings
.project
.classpath
.c9/

# Debugging
debug.log
goss-wait.log

# Azure resources cache
.az/

